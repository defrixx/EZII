FROM node:22-alpine AS deps
WORKDIR /app
COPY package.json ./
RUN npm install

FROM node:22-alpine AS builder
WORKDIR /app
ARG NEXT_PUBLIC_KEYCLOAK_URL
ARG NEXT_PUBLIC_KEYCLOAK_REALM
ARG NEXT_PUBLIC_KEYCLOAK_CLIENT_ID
ARG NEXT_PUBLIC_KEYCLOAK_REDIRECT_URI
ARG NEXT_PUBLIC_REGISTER_ENFORCE_CAPTCHA
ARG NEXT_PUBLIC_REGISTER_CAPTCHA_PROVIDER
ARG NEXT_PUBLIC_REGISTER_TURNSTILE_SITE_KEY
ARG NEXT_PUBLIC_REGISTER_HCAPTCHA_SITE_KEY
ENV NEXT_PUBLIC_KEYCLOAK_URL=$NEXT_PUBLIC_KEYCLOAK_URL
ENV NEXT_PUBLIC_KEYCLOAK_REALM=$NEXT_PUBLIC_KEYCLOAK_REALM
ENV NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=$NEXT_PUBLIC_KEYCLOAK_CLIENT_ID
ENV NEXT_PUBLIC_KEYCLOAK_REDIRECT_URI=$NEXT_PUBLIC_KEYCLOAK_REDIRECT_URI
ENV NEXT_PUBLIC_REGISTER_ENFORCE_CAPTCHA=$NEXT_PUBLIC_REGISTER_ENFORCE_CAPTCHA
ENV NEXT_PUBLIC_REGISTER_CAPTCHA_PROVIDER=$NEXT_PUBLIC_REGISTER_CAPTCHA_PROVIDER
ENV NEXT_PUBLIC_REGISTER_TURNSTILE_SITE_KEY=$NEXT_PUBLIC_REGISTER_TURNSTILE_SITE_KEY
ENV NEXT_PUBLIC_REGISTER_HCAPTCHA_SITE_KEY=$NEXT_PUBLIC_REGISTER_HCAPTCHA_SITE_KEY
COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN npm run build

FROM node:22-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
EXPOSE 3000
CMD ["node", "server.js"]
