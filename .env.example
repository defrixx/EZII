APP_NAME=Glossary-First Assistant
# Runtime mode (production/dev). Impacts security behavior and logging profile.
APP_ENV=production
# Enables verbose debug diagnostics (keep false in production).
DEBUG=false
CORS_ORIGINS=http://localhost,http://127.0.0.1

POSTGRES_USER=app
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=postgres
APP_DB_NAME=app
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_ADMIN=kc_admin
KEYCLOAK_ADMIN_PASSWORD=change-me-strong-password

DATABASE_URL=postgresql+psycopg2://app:app@postgres:5432/app
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=glossary_entries

KEYCLOAK_SERVER_URL=http://keycloak:8080
# Token issuer URL embedded into JWTs (public Keycloak URL seen by browser).
KEYCLOAK_ISSUER=http://localhost:8080
KEYCLOAK_REALM=ezii
KEYCLOAK_AUDIENCE=assistant-api
KEYCLOAK_HOSTNAME=auth.localhost
KEYCLOAK_ADMIN_REALM=master
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
DEFAULT_TENANT_ID=
REGISTER_REQUIRE_EMAIL_VERIFICATION=true
REGISTER_REQUIRES_ADMIN_APPROVAL=false
REGISTER_ENFORCE_CAPTCHA=true
REGISTER_CAPTCHA_PROVIDER=builtin
REGISTER_BUILTIN_CAPTCHA_TTL_S=180
TURNSTILE_SECRET_KEY=
HCAPTCHA_SECRET_KEY=
OIDC_FRONTEND_CLIENT_ID=ezii-frontend
OIDC_FRONTEND_REDIRECT_URI=http://localhost/auth/callback
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=ezii
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=ezii-frontend
NEXT_PUBLIC_KEYCLOAK_REDIRECT_URI=http://localhost/auth/callback
NEXT_PUBLIC_OIDC_SCOPES=openid
NEXT_PUBLIC_REGISTER_ENFORCE_CAPTCHA=true
NEXT_PUBLIC_REGISTER_CAPTCHA_PROVIDER=builtin
NEXT_PUBLIC_REGISTER_TURNSTILE_SITE_KEY=
NEXT_PUBLIC_REGISTER_HCAPTCHA_SITE_KEY=

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=replace-with-real-key
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_VECTOR_SIZE=1536
PROVIDER_TIMEOUT_S=30
PROVIDER_MAX_RETRIES=2
PROVIDER_API_KEY_ENCRYPTION_KEY=

RATE_LIMIT_PER_MINUTE=60
REGISTER_CAPTCHA_RATE_LIMIT_PER_IP_PER_HOUR=120
# Keep false in production so abuse protections remain active when Redis degrades.
RATE_LIMIT_FAIL_OPEN=false
# Force Secure cookies (requires HTTPS). Set false only for local HTTP testing.
AUTH_COOKIE_SECURE=true
# Cookie CSRF posture: lax/strict/none.
AUTH_COOKIE_SAMESITE=lax
